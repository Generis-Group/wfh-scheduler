generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  EMPLOYEE
  COO
  ADMIN
}

enum UserStatus {
  INVITED
  ACTIVE
  DISABLED
}

enum WorkLocation {
  OFFICE
  WFH
  HYBRID
  PTO
  OUT_OF_OFFICE
  UNKNOWN
}

enum ReportStatus {
  DRAFT
  SUBMITTED
}

enum ActivitySource {
  JIRA
  GOOGLE_CALENDAR
  GOOGLE_TASKS
  MANUAL
}

enum SyncProvider {
  JIRA
  GOOGLE_CALENDAR
  GOOGLE_TASKS
}

enum SyncStatus {
  RUNNING
  SUCCEEDED
  FAILED
}

model User {
  id                   String                   @id @default(cuid())
  name                 String?
  email                String?                  @unique
  emailVerified        DateTime?
  image                String?
  role                 UserRole                 @default(EMPLOYEE)
  status               UserStatus               @default(INVITED)
  timezone             String                   @default("America/Toronto")
  passwordHash         String?
  mustChangePassword   Boolean                  @default(false)
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  accounts             Account[]
  sessions             Session[]
  reports              DailyReport[]
  activities           ActivityItem[]
  comments             ReportComment[]          @relation("CommentAuthor")
  revisions            ReportRevision[]         @relation("RevisionEditor")
  syncRuns             SyncRun[]
  integrationSettings  UserIntegrationSettings?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserIntegrationSettings {
  id                    String   @id @default(cuid())
  userId                String   @unique
  jiraCloudId           String?
  jiraAccountId         String?
  googleCalendarId      String   @default("primary")
  googleTaskListIds     String[]
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DailyReport {
  id           String          @id @default(cuid())
  userId       String
  reportDate   DateTime        @db.Date
  workLocation WorkLocation    @default(UNKNOWN)
  summary      String          @default("") @db.Text
  blockers     String          @default("") @db.Text
  status       ReportStatus    @default(DRAFT)
  submittedAt  DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  activities   ActivityItem[]
  comments     ReportComment[]
  revisions    ReportRevision[]

  @@unique([userId, reportDate])
  @@index([reportDate, status])
}

model ActivityItem {
  id                String         @id @default(cuid())
  userId            String
  dailyReportId     String?
  reportDate        DateTime       @db.Date
  source            ActivitySource
  sourceId          String?
  sourceContainerId String?
  title             String
  description       String?        @db.Text
  status            String?
  sourceUrl         String?
  startedAt         DateTime?
  endedAt           DateTime?
  durationMinutes   Int?
  selected          Boolean        @default(true)
  employeeNote      String?        @db.Text
  metadata          Json?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyReport       DailyReport?   @relation(fields: [dailyReportId], references: [id], onDelete: SetNull)

  @@index([userId, reportDate])
  @@index([source, sourceId])
  @@unique([userId, reportDate, source, sourceId])
}

model ReportRevision {
  id          String      @id @default(cuid())
  reportId    String
  editedById  String
  snapshot    Json
  createdAt   DateTime    @default(now())
  report      DailyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  editedBy    User        @relation("RevisionEditor", fields: [editedById], references: [id], onDelete: Cascade)

  @@index([reportId, createdAt])
}

model ReportComment {
  id        String      @id @default(cuid())
  reportId  String
  authorId  String
  body      String      @db.Text
  createdAt DateTime    @default(now())
  report    DailyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  author    User        @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([reportId, createdAt])
}

model SyncRun {
  id            String       @id @default(cuid())
  userId        String
  provider      SyncProvider
  rangeStart    DateTime     @db.Date
  rangeEnd      DateTime     @db.Date
  status        SyncStatus   @default(RUNNING)
  importedCount Int          @default(0)
  skippedCount  Int          @default(0)
  errorMessage  String?      @db.Text
  createdAt     DateTime     @default(now())
  completedAt   DateTime?
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, provider, createdAt])
}

model AppSetting {
  key       String   @id
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/generis_reporting?schema=public&connection_limit=1"
PRISMA_CONNECTION_LIMIT="1"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
TOKEN_ENCRYPTION_KEY="replace-with-32-byte-base64-or-long-secret"

ATLASSIAN_CLIENT_ID=""
ATLASSIAN_CLIENT_SECRET=""

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Gemini uses each user's connected Google account. Set a Google Cloud project with the Gemini API enabled.
GOOGLE_CLOUD_QUOTA_PROJECT=""
# Optional fallback when GOOGLE_CLOUD_QUOTA_PROJECT is not set.
GOOGLE_CLOUD_PROJECT=""
# Optional; defaults to gemini-2.5-flash.
GEMINI_MODEL="gemini-2.5-flash"

# Optional HubSpot logged-hours import. Object/property names depend on the HubSpot data input schema.
HUBSPOT_PRIVATE_APP_TOKEN=""
HUBSPOT_LOGGED_HOURS_OBJECT_TYPE=""
HUBSPOT_LOGGED_HOURS_DATE_PROPERTY=""
HUBSPOT_LOGGED_HOURS_DURATION_PROPERTY=""
HUBSPOT_LOGGED_HOURS_USER_EMAIL_PROPERTY=""
# Optional; defaults to task_name,project_name,name,title,subject.
HUBSPOT_LOGGED_HOURS_TITLE_PROPERTIES=""
# Optional; defaults to description,notes,comment.
HUBSPOT_LOGGED_HOURS_DESCRIPTION_PROPERTIES=""
# Optional; defaults to hours. Allowed values: hours, minutes, seconds.
HUBSPOT_LOGGED_HOURS_DURATION_UNIT="hours"
# Optional; defaults to epochMillis. Allowed values: epochMillis, iso, date.
HUBSPOT_LOGGED_HOURS_DATE_FILTER_FORMAT="epochMillis"
# Optional; defaults to https://api.hubapi.com and 2026-03.
HUBSPOT_API_BASE_URL=""
HUBSPOT_CRM_API_VERSION=""
# Optional properties for richer imported items.
HUBSPOT_LOGGED_HOURS_STATUS_PROPERTY=""
HUBSPOT_LOGGED_HOURS_URL_PROPERTY=""

RESEND_API_KEY=""
# Optional; defaults to "Generis Reports <reports@generisgp.com>".
EMAIL_FROM="Generis Reports <reports@generisgp.com>"
# Public URL used in outbound email links. Do not set this to localhost.
APP_BASE_URL="https://report.generisgp.com"
CRON_SECRET="replace-with-a-long-random-secret"

INITIAL_ADMIN_EMAIL="admin@generisgp.com"
INITIAL_ADMIN_PASSWORD="ChangeMe123!"
